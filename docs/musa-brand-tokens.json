{
  "$schema": "https://design-tokens.github.io/community-group/format/",
  "$description": "Musa Brand Design Tokens — DTCG Format",
  "$version": "1.0.0",
  "color": {
    "primary": {
      "50":  { "$value": "#f0fdf4", "$type": "color" },
      "100": { "$value": "#dcfce7", "$type": "color" },
      "200": { "$value": "#bbf7d0", "$type": "color" },
      "300": { "$value": "#86efac", "$type": "color" },
      "400": { "$value": "#4ade80", "$type": "color" },
      "500": { "$value": "#22c55e", "$type": "color", "$description": "Main brand color — CTAs, links, accents" },
      "600": { "$value": "#16a34a", "$type": "color" },
      "700": { "$value": "#15803d", "$type": "color" },
      "800": { "$value": "#166534", "$type": "color" },
      "900": { "$value": "#14532d", "$type": "color" },
      "950": { "$value": "#052e16", "$type": "color" }
    },
    "neutral": {
      "50":  { "$value": "#fafafa", "$type": "color" },
      "100": { "$value": "#f4f4f5", "$type": "color" },
      "200": { "$value": "#e4e4e7", "$type": "color" },
      "300": { "$value": "#d4d4d8", "$type": "color" },
      "400": { "$value": "#a1a1aa", "$type": "color" },
      "500": { "$value": "#71717a", "$type": "color" },
      "600": { "$value": "#52525b", "$type": "color" },
      "700": { "$value": "#3f3f46", "$type": "color" },
      "800": { "$value": "#27272a", "$type": "color" },
      "900": { "$value": "#18181b", "$type": "color" },
      "950": { "$value": "#09090b", "$type": "color" }
    },
    "accent": {
      "300": { "$value": "#c4b5fd", "$type": "color" },
      "400": { "$value": "#a78bfa", "$type": "color", "$description": "Main accent — contrast with green" },
      "500": { "$value": "#8b5cf6", "$type": "color" },
      "600": { "$value": "#7c3aed", "$type": "color" }
    },
    "semantic": {
      "success": { "$value": "#22c55e", "$type": "color" },
      "error":   { "$value": "#ef4444", "$type": "color" },
      "warning": { "$value": "#f59e0b", "$type": "color" },
      "info":    { "$value": "#3b82f6", "$type": "color" }
    },
    "surface": {
      "background": { "$value": "#09090b", "$type": "color", "$description": "Page background" },
      "1": { "$value": "#0f0f12", "$type": "color", "$description": "Cards, panels" },
      "2": { "$value": "#18181b", "$type": "color", "$description": "Elevated surfaces" },
      "3": { "$value": "#1f1f23", "$type": "color", "$description": "Highest elevation" }
    },
    "text": {
      "primary":   { "$value": "#fafafa", "$type": "color" },
      "secondary": { "$value": "#a1a1aa", "$type": "color" },
      "muted":     { "$value": "#71717a", "$type": "color" }
    },
    "border": {
      "default": { "$value": "rgba(255,255,255,0.06)", "$type": "color" },
      "hover":   { "$value": "rgba(34,197,94,0.3)", "$type": "color" },
      "focus":   { "$value": "rgba(34,197,94,0.5)", "$type": "color" }
    }
  },
  "typography": {
    "fontFamily": {
      "display":  { "$value": "'Space Grotesk', system-ui, sans-serif", "$type": "fontFamily", "$description": "Headlines, hero text" },
      "body":     { "$value": "'Inter', system-ui, sans-serif", "$type": "fontFamily", "$description": "Body text, UI" },
      "mono":     { "$value": "'Geist Mono', 'Fira Code', monospace", "$type": "fontFamily", "$description": "Code, technical" }
    },
    "fontSize": {
      "xs":    { "$value": "0.75rem", "$type": "dimension" },
      "sm":    { "$value": "0.875rem", "$type": "dimension" },
      "base":  { "$value": "1rem", "$type": "dimension" },
      "lg":    { "$value": "1.125rem", "$type": "dimension" },
      "xl":    { "$value": "1.25rem", "$type": "dimension" },
      "2xl":   { "$value": "1.5rem", "$type": "dimension" },
      "3xl":   { "$value": "1.875rem", "$type": "dimension" },
      "4xl":   { "$value": "2.25rem", "$type": "dimension" },
      "5xl":   { "$value": "3rem", "$type": "dimension" },
      "6xl":   { "$value": "3.5rem", "$type": "dimension" },
      "7xl":   { "$value": "4.5rem", "$type": "dimension" }
    },
    "fontWeight": {
      "regular":  { "$value": "400", "$type": "fontWeight" },
      "medium":   { "$value": "500", "$type": "fontWeight" },
      "semibold": { "$value": "600", "$type": "fontWeight" },
      "bold":     { "$value": "700", "$type": "fontWeight" },
      "extrabold":{ "$value": "800", "$type": "fontWeight" }
    },
    "lineHeight": {
      "none":    { "$value": "1", "$type": "number" },
      "tight":   { "$value": "1.05", "$type": "number" },
      "snug":    { "$value": "1.2", "$type": "number" },
      "normal":  { "$value": "1.5", "$type": "number" },
      "relaxed": { "$value": "1.625", "$type": "number" },
      "loose":   { "$value": "2", "$type": "number" }
    },
    "letterSpacing": {
      "tighter": { "$value": "-0.05em", "$type": "dimension" },
      "tight":   { "$value": "-0.025em", "$type": "dimension" },
      "normal":  { "$value": "0em", "$type": "dimension" },
      "wide":    { "$value": "0.025em", "$type": "dimension" },
      "wider":   { "$value": "0.05em", "$type": "dimension" },
      "widest":  { "$value": "0.1em", "$type": "dimension" }
    }
  },
  "spacing": {
    "0":   { "$value": "0px", "$type": "dimension" },
    "0.5": { "$value": "2px", "$type": "dimension" },
    "1":   { "$value": "4px", "$type": "dimension" },
    "1.5": { "$value": "6px", "$type": "dimension" },
    "2":   { "$value": "8px", "$type": "dimension" },
    "2.5": { "$value": "10px", "$type": "dimension" },
    "3":   { "$value": "12px", "$type": "dimension" },
    "4":   { "$value": "16px", "$type": "dimension" },
    "5":   { "$value": "20px", "$type": "dimension" },
    "6":   { "$value": "24px", "$type": "dimension" },
    "8":   { "$value": "32px", "$type": "dimension" },
    "10":  { "$value": "40px", "$type": "dimension" },
    "12":  { "$value": "48px", "$type": "dimension" },
    "16":  { "$value": "64px", "$type": "dimension" },
    "20":  { "$value": "80px", "$type": "dimension" },
    "24":  { "$value": "96px", "$type": "dimension" },
    "32":  { "$value": "128px", "$type": "dimension" }
  },
  "borderRadius": {
    "none": { "$value": "0px", "$type": "dimension" },
    "sm":   { "$value": "4px", "$type": "dimension" },
    "md":   { "$value": "8px", "$type": "dimension" },
    "lg":   { "$value": "12px", "$type": "dimension" },
    "xl":   { "$value": "16px", "$type": "dimension" },
    "2xl":  { "$value": "24px", "$type": "dimension" },
    "full": { "$value": "9999px", "$type": "dimension" }
  },
  "shadow": {
    "sm":   { "$value": "0 1px 2px rgba(0,0,0,0.3)", "$type": "shadow" },
    "md":   { "$value": "0 4px 6px -1px rgba(0,0,0,0.4)", "$type": "shadow" },
    "lg":   { "$value": "0 10px 15px -3px rgba(0,0,0,0.5)", "$type": "shadow" },
    "xl":   { "$value": "0 20px 25px -5px rgba(0,0,0,0.5)", "$type": "shadow" },
    "2xl":  { "$value": "0 25px 50px -12px rgba(0,0,0,0.6)", "$type": "shadow" },
    "glow": { "$value": "0 0 20px rgba(34,197,94,0.3)", "$type": "shadow", "$description": "Green glow for emphasis" },
    "glow-lg": { "$value": "0 0 40px rgba(34,197,94,0.2), 0 0 80px rgba(34,197,94,0.1)", "$type": "shadow" }
  },
  "animation": {
    "duration": {
      "fast":    { "$value": "150ms", "$type": "duration" },
      "normal":  { "$value": "300ms", "$type": "duration" },
      "slow":    { "$value": "500ms", "$type": "duration" },
      "slower":  { "$value": "700ms", "$type": "duration" }
    },
    "easing": {
      "default":  { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
      "in":       { "$value": "cubic-bezier(0.4, 0, 1, 1)", "$type": "cubicBezier" },
      "out":      { "$value": "cubic-bezier(0, 0, 0.2, 1)", "$type": "cubicBezier" },
      "in-out":   { "$value": "cubic-bezier(0.4, 0, 0.2, 1)", "$type": "cubicBezier" },
      "spring":   { "$value": "cubic-bezier(0.34, 1.56, 0.64, 1)", "$type": "cubicBezier" }
    }
  },
  "component": {
    "button": {
      "primary": {
        "bg": { "$value": "#22c55e", "$type": "color" },
        "bgHover": { "$value": "#16a34a", "$type": "color" },
        "text": { "$value": "#052e16", "$type": "color" },
        "borderRadius": { "$value": "8px", "$type": "dimension" },
        "paddingX": { "$value": "24px", "$type": "dimension" },
        "paddingY": { "$value": "12px", "$type": "dimension" },
        "fontSize": { "$value": "0.875rem", "$type": "dimension" },
        "fontWeight": { "$value": "600", "$type": "fontWeight" }
      },
      "secondary": {
        "bg": { "$value": "transparent", "$type": "color" },
        "border": { "$value": "rgba(255,255,255,0.1)", "$type": "color" },
        "borderHover": { "$value": "rgba(34,197,94,0.3)", "$type": "color" },
        "text": { "$value": "#fafafa", "$type": "color" }
      },
      "ghost": {
        "bg": { "$value": "transparent", "$type": "color" },
        "bgHover": { "$value": "rgba(255,255,255,0.05)", "$type": "color" },
        "text": { "$value": "#a1a1aa", "$type": "color" },
        "textHover": { "$value": "#fafafa", "$type": "color" }
      },
      "sizes": {
        "sm": { "paddingX": { "$value": "12px" }, "paddingY": { "$value": "6px" }, "fontSize": { "$value": "0.75rem" } },
        "md": { "paddingX": { "$value": "24px" }, "paddingY": { "$value": "12px" }, "fontSize": { "$value": "0.875rem" } },
        "lg": { "paddingX": { "$value": "32px" }, "paddingY": { "$value": "16px" }, "fontSize": { "$value": "1rem" } }
      }
    },
    "card": {
      "bg": { "$value": "rgba(255,255,255,0.02)", "$type": "color" },
      "border": { "$value": "rgba(255,255,255,0.06)", "$type": "color" },
      "borderRadius": { "$value": "12px", "$type": "dimension" },
      "padding": { "$value": "24px", "$type": "dimension" },
      "backdropBlur": { "$value": "12px", "$type": "dimension" }
    },
    "input": {
      "bg": { "$value": "rgba(255,255,255,0.03)", "$type": "color" },
      "border": { "$value": "rgba(255,255,255,0.08)", "$type": "color" },
      "borderFocus": { "$value": "rgba(34,197,94,0.5)", "$type": "color" },
      "borderRadius": { "$value": "8px", "$type": "dimension" },
      "padding": { "$value": "12px 16px", "$type": "dimension" },
      "fontSize": { "$value": "0.875rem", "$type": "dimension" }
    }
  },
  "voice": {
    "personality": ["Direto", "Empoderador", "Tech-savvy", "Confiante", "Acessível"],
    "tone": "Profissional mas acessível. Sem jargão desnecessário. Foco em resultados concretos.",
    "avoid": ["Linguagem passiva", "Promessas vagas", "Excesso de emojis", "Tom corporativo frio"]
  }
}
